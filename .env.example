# ─────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─────────────────────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# ─────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────
# Use * to allow all origins, or set a specific origin:
# CORS_ORIGIN=http://localhost:8083
CORS_ORIGIN=*

# ─────────────────────────────────────────────────────────
# Firebase Admin SDK
# ─────────────────────────────────────────────────────────
# Obtidos em: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Mantenha as quebras de linha como \n (string única entre aspas)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
